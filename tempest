#!/usr/bin/env php
<?php

$arg = $_SERVER['argv'];
if (($arg[1] ?? null) === 'data:parse') {
    require __DIR__ . '/app/Parser.php';
    require __DIR__ . '/app/Commands/Visit.php';
    $inputPath = \substr($arg[2] ?? '', 13);
    $outputPath = \substr($arg[3] ?? '', 14);
    \App\Parser::parse($inputPath, $outputPath);
    exit(0);
}

use Tempest\Console\ConsoleApplication;
require_once getcwd() . '/vendor/autoload.php';
ConsoleApplication::boot()->run();
exit();
